# ================================================================
# LDS YSA Connect — Backend Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ================================================================

# Server
PORT=4000
NODE_ENV=development

# CORS — set to your Flutter app origin or API gateway in production
CORS_ORIGIN=http://localhost:3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lds_ysa_db
DB_USER=lds_admin
DB_PASSWORD=CHANGE_ME_strong_db_password

# Prisma — keep in sync with DB_* values above
DATABASE_URL=postgresql://lds_admin:CHANGE_ME_strong_db_password@localhost:5432/lds_ysa_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_min_64_random_chars
JWT_EXPIRES_IN=7d

# Storage
STORAGE_TYPE=local
LOCAL_UPLOAD_PATH=./uploads
AWS_BUCKET=your-s3-bucket-name
AWS_REGION=us-east-1
AWS_ACCESS_KEY=
AWS_SECRET_KEY=

# MaaS360 MDM (missionary device management)
MAAS360_TENANT_ID=
MAAS360_USERNAME=
MAAS360_PASSWORD=
MAAS360_APP_ID=
MAAS360_APP_ACCESS_KEY=

# Push Notifications — Firebase Admin SDK (FCM HTTP v1)
# Download service account JSON from:
# Firebase Console → Project Settings → Service accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.yourchurch.lds.ysa

# App Config
MAX_GROUP_SIZE=1000
MAX_PINNED_CHATS=3
SCRIPTURE_ROTATE_MINS=5
